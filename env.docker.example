# ============================================================
# AI Wedding - Docker 部署配置
# ============================================================
#
# 使用方法：
#   1. cp env.docker.example .env
#   2. 修改下面标记为 [必改] 的配置
#   3. 运行 bash deploy.sh
#
# ============================================================

# ============================================================
# [必改] AI 模型配置
# ============================================================
IMAGE_API_MODE=images
IMAGE_API_BASE_URL=https://api.openai.com
IMAGE_API_KEY=sk-your-api-key-here
IMAGE_IMAGE_MODEL=dall-e-3
IMAGE_CHAT_MODEL=gemini-2.5-flash-image

# ============================================================
# [必改] 管理员账号（首次部署自动创建）
# ============================================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# ============================================================
# [必改] NextAuth 配置
# ============================================================
# 生产环境请使用 HTTPS 地址
NEXTAUTH_URL=http://localhost:3000
# 生成命令: openssl rand -base64 32
NEXTAUTH_SECRET=please-change-this-secret-in-production

# ============================================================
# [可选] 对象存储 - 默认使用 MinIO（自托管）
# ============================================================
# 选项: minio | oss
STORAGE_PROVIDER=minio

# MinIO 配置（使用 MinIO 时生效）
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ai-images
MINIO_USE_SSL=false
# 外部访问地址（用于图片 URL 返回给浏览器）
# 部署到服务器时改为服务器的 IP 或域名，例如 http://your-server-ip:9000
MINIO_ENDPOINT=http://localhost:9000
# 内部连接地址（Docker 容器间通信，无需修改）
# MINIO_INTERNAL_ENDPOINT=http://minio:9000

# 阿里云 OSS 配置（STORAGE_PROVIDER=oss 时生效）
# ALI_OSS_REGION=oss-cn-beijing
# ALI_OSS_ACCESS_KEY_ID=
# ALI_OSS_ACCESS_KEY_SECRET=
# ALI_OSS_BUCKET=

# ============================================================
# [可选] 数据库配置（Docker Compose 内部使用）
# ============================================================
POSTGRES_USER=aiwedding
POSTGRES_PASSWORD=aiwedding123
POSTGRES_DB=ai_wedding
POSTGRES_PORT=5433

# ============================================================
# [可选] 端口配置
# ============================================================
APP_PORT=3000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================================
# [可选] 应用配置
# ============================================================
ENABLE_SSR_GUARD=true
PAYMENT_PROVIDER=mock
# SKIP_MIGRATIONS=false
# SKIP_SEED=false

# ============================================================
# [可选] Seed 数据模型配置
# ============================================================
# 如果不设置，使用 IMAGE_API_KEY / IMAGE_API_BASE_URL
# SEED_MODEL_API_KEY=
# SEED_MODEL_API_BASE_URL=

# ============================================================
# [可选] 时区
# ============================================================
TZ=Asia/Shanghai
