generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model credit_transactions {
  id              String                  @id @default(cuid())
  user_id         String
  type            CreditTransactionType
  status          CreditTransactionStatus @default(pending)
  amount          Int
  balance_before  Int
  balance_after   Int
  generation_id   String?
  order_id        String?
  invite_event_id String?
  description     String?
  metadata        Json?
  created_by      String?
  created_at      DateTime                @default(now())
  completed_at    DateTime?
  users           users                   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([generation_id])
  @@index([order_id])
  @@index([status])
  @@index([type])
  @@index([user_id])
}

model domains {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  icon        String   @default("Camera")
  color       String   @default("from-pink-500 to-rose-500")
  cover_image           String?
  is_active             Boolean  @default(true)
  sort_order            Int      @default(0)
  require_face_detection Boolean @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([is_active])
  @@index([sort_order])
}

model favorites {
  id          String    @id @default(cuid())
  user_id     String
  template_id String
  created_at  DateTime  @default(now())
  templates   templates @relation(fields: [template_id], references: [id], onDelete: Cascade)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, template_id])
  @@index([template_id])
  @@index([user_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model generated_images {
  id            String      @id @default(cuid())
  generation_id String
  image_url     String
  image_type    ImageType   @default(preview)
  image_index   Int         @default(0)
  metadata      Json?
  created_at    DateTime    @default(now())
  generations   generations @relation(fields: [generation_id], references: [id], onDelete: Cascade)

  @@index([generation_id])
  @@index([image_type])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model generations {
  id                   String             @id @default(cuid())
  project_id           String?
  user_id              String
  template_id          String?
  domain               String             @default("wedding")
  status               String             @default("pending")
  preview_images       Json               @default("[]")
  high_res_images      Json               @default("[]")
  error_message        String?
  credits_used         Int                @default(0)
  is_shared_to_gallery Boolean            @default(false)
  completed_at         DateTime?
  created_at           DateTime           @default(now())
  updated_at           DateTime @updatedAt
  generation_type      GenerationType?    @default(batch)
  prompt               String?
  original_image       String?
  settings             Json?
  generated_images     generated_images[]
  projects             projects?          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  templates            templates?         @relation(fields: [template_id], references: [id])
  users                users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  image_downloads      image_downloads[]
  image_likes          image_likes[]
  orders               orders[]

  @@index([created_at])
  @@index([domain])
  @@index([generation_type])
  @@index([project_id])
  @@index([status])
  @@index([template_id])
  @@index([user_id])
}

model image_downloads {
  id            String      @id @default(cuid())
  user_id       String
  generation_id String
  image_index   Int
  image_type    String      @default("preview")
  order_id      String?
  created_at    DateTime    @default(now())
  generations   generations @relation(fields: [generation_id], references: [id], onDelete: Cascade)
  orders        orders?     @relation(fields: [order_id], references: [id])
  users         users       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([generation_id])
  @@index([user_id])
}

model image_likes {
  id            String      @id @default(cuid())
  user_id       String
  generation_id String
  image_index   Int
  image_type    String      @default("preview")
  created_at    DateTime    @default(now())
  generations   generations @relation(fields: [generation_id], references: [id], onDelete: Cascade)
  users         users       @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([generation_id])
  @@index([user_id])
}

model invite_events {
  id                                    String   @id @default(cuid())
  inviter_id                            String?
  invitee_id                            String?
  inviter_code                          String?
  reward_credits                        Int      @default(0)
  created_at                            DateTime @default(now())
  users_invite_events_invitee_idTousers users?   @relation("invite_events_invitee_idTousers", fields: [invitee_id], references: [id])
  users_invite_events_inviter_idTousers users?   @relation("invite_events_inviter_idTousers", fields: [inviter_id], references: [id])

  @@index([created_at])
  @@index([invitee_id])
  @@index([inviter_id])
}

model model_configs {
  id           String            @id @default(cuid())
  type         ModelConfigType
  name         String
  api_base_url String
  api_key      String
  model_name   String
  status       ModelConfigStatus @default(inactive)
  description  String?
  source       ModelConfigSource @default(openAi)
  created_by   String?
  created_at   DateTime          @default(now())
  updated_at   DateTime @updatedAt
  users        users?            @relation(fields: [created_by], references: [id])

  @@index([status])
  @@index([type])
}

model orders {
  id                String            @id @default(cuid())
  user_id           String
  generation_id     String?
  amount            Decimal           @db.Decimal(12, 2)
  currency          String            @default("USD")
  status            String            @default("pending")
  payment_method    String?
  payment_intent_id String?
  purchased_images  Json              @default("[]")
  created_at        DateTime          @default(now())
  updated_at        DateTime @updatedAt
  image_downloads   image_downloads[]
  generations       generations?      @relation(fields: [generation_id], references: [id])
  users             users             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([generation_id])
  @@index([status])
  @@index([user_id])
}

model profiles {
  id             String   @id @default(cuid())
  user_id        String   @unique
  credits        Int      @default(50)
  invite_code    String?  @unique
  invited_by     String?
  invite_count   Int      @default(0)
  reward_credits Int      @default(0)
  role           String   @default("user")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  frozen_credits Int      @default(0)
  users          users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model projects {
  id              String        @id @default(cuid())
  user_id         String
  name            String
  domain          String        @default("wedding")
  status          String        @default("draft")
  uploaded_photos Json          @default("[]")
  created_at      DateTime      @default(now())
  updated_at      DateTime @updatedAt
  generations     generations[]
  users           users         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([created_at])
  @@index([domain])
  @@index([status])
  @@index([user_id])
}

model system_announcements {
  id           String   @id @default(cuid())
  content      String
  is_active    Boolean  @default(false)
  published_at DateTime @default(now())
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([is_active])
  @@index([published_at])
}

model templates {
  id                String        @id @default(cuid())
  name              String
  description       String?
  category          String
  domain            String        @default("wedding")
  preview_image_url String?
  prompt_config     Json          @default("{}")
  prompt_list       Json          @default("[]")
  price_credits     Int           @default(10)
  is_active         Boolean       @default(true)
  sort_order        Int           @default(0)
  created_at        DateTime      @default(now())
  favorites         favorites[]
  generations       generations[]

  @@index([category])
  @@index([domain])
  @@index([is_active])
}

model users {
  id                                            String                @id @default(cuid())
  email                                         String                @unique
  password_hash                                 String
  name                                          String?
  image                                         String?
  email_verified                                DateTime?
  created_at                                    DateTime              @default(now())
  updated_at                                    DateTime @updatedAt
  credit_transactions                           credit_transactions[]
  favorites                                     favorites[]
  generations                                   generations[]
  image_downloads                               image_downloads[]
  image_likes                                   image_likes[]
  invite_events_invite_events_invitee_idTousers invite_events[]       @relation("invite_events_invitee_idTousers")
  invite_events_invite_events_inviter_idTousers invite_events[]       @relation("invite_events_inviter_idTousers")
  model_configs                                 model_configs[]
  orders                                        orders[]
  profiles                                      profiles?
  projects                                      projects[]
}

enum CreditTransactionStatus {
  pending
  completed
  failed
  cancelled
}

enum CreditTransactionType {
  purchase
  generation
  refund
  invite_reward
  system_grant
  admin_adjust
}

enum GenerationType {
  batch
  single
}

enum ImageType {
  preview
  high_res
}

enum ModelConfigSource {
  openRouter
  openAi
  // 302 @map("302")
}

enum ModelConfigStatus {
  active
  inactive
}

enum ModelConfigType {
  generate_image   @map("generate-image")
  identify_image   @map("identify-image")
  generate_prompts @map("generate-prompts")
  other
}
