// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ModelConfigType {
  generate_image    @map("generate-image")
  identify_image    @map("identify-image")
  generate_prompts   @map("generate-prompts")
  other
}

enum ModelConfigStatus {
  active
  inactive
}

enum ModelConfigSource {
  openRouter  @map("openRouter")
  openAi      @map("openAi")
  source_302  @map("302")
}

// ---------------------------------------------------------------------------
// User & Profile (NextAuth)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  profile             Profile?
  projects            Project[]
  generations         Generation[]
  orders              Order[]
  favorites           Favorite[]
  imageDownloads      ImageDownload[]
  imageLikes          ImageLike[]
  singleGenerations   SingleGeneration[]
  inviteEventsAsInviter InviteEvent[] @relation("InviterEvents")
  inviteEventsAsInvitee InviteEvent[] @relation("InviteeEvents")
  modelConfigsCreated ModelConfig[]

  @@map("users")
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  credits       Int      @default(50)
  inviteCode    String?  @unique @map("invite_code")
  invitedBy     String?  @map("invited_by")
  inviteCount   Int      @default(0) @map("invite_count")
  rewardCredits Int      @default(0) @map("reward_credits")
  role          String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ---------------------------------------------------------------------------
// Templates
// ---------------------------------------------------------------------------

model Template {
  id               String   @id @default(cuid())
  name             String
  description      String?
  category         String
  domain           String   @default("wedding")
  previewImageUrl  String?  @map("preview_image_url")
  promptConfig     Json     @default("{}") @map("prompt_config")
  promptList       Json     @default("[]") @map("prompt_list")
  priceCredits     Int      @default(10) @map("price_credits")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")

  generations Generation[]
  favorites   Favorite[]

  @@index([domain])
  @@index([category])
  @@index([isActive])
  @@map("templates")
}

// ---------------------------------------------------------------------------
// Projects
// ---------------------------------------------------------------------------

model Project {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  domain         String   @default("wedding")
  status         String   @default("draft")
  uploadedPhotos Json     @default("[]") @map("uploaded_photos")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations  Generation[]

  @@index([userId])
  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("projects")
}

// ---------------------------------------------------------------------------
// Generations
// ---------------------------------------------------------------------------

model Generation {
  id                 String    @id @default(cuid())
  projectId          String    @map("project_id")
  userId             String    @map("user_id")
  templateId         String?   @map("template_id")
  domain             String    @default("wedding")
  status             String    @default("pending")
  previewImages      Json      @default("[]") @map("preview_images")
  highResImages      Json      @default("[]") @map("high_res_images")
  errorMessage       String?   @map("error_message")
  creditsUsed        Int       @default(0) @map("credits_used")
  isSharedToGallery  Boolean   @default(false) @map("is_shared_to_gallery")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       Template?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  orders         Order[]
  imageDownloads ImageDownload[]
  imageLikes     ImageLike[]

  @@index([userId])
  @@index([projectId])
  @@index([templateId])
  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("generations")
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

model Order {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  generationId     String?  @map("generation_id")
  amount           Decimal  @db.Decimal(12, 2)
  currency         String   @default("USD")
  status           String   @default("pending")
  paymentMethod    String?  @map("payment_method")
  paymentIntentId  String?  @map("payment_intent_id")
  purchasedImages  Json     @default("[]") @map("purchased_images")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation   Generation?  @relation(fields: [generationId], references: [id], onDelete: SetNull)
  imageDownloads ImageDownload[]

  @@index([userId])
  @@index([generationId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// ---------------------------------------------------------------------------
// Favorites
// ---------------------------------------------------------------------------

model Favorite {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  templateId String   @map("template_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([userId])
  @@index([templateId])
  @@map("favorites")
}

// ---------------------------------------------------------------------------
// Image Downloads
// ---------------------------------------------------------------------------

model ImageDownload {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  generationId String   @map("generation_id")
  imageIndex   Int      @map("image_index")
  imageType    String   @default("preview") @map("image_type")
  orderId      String?  @map("order_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation  @relation(fields: [generationId], references: [id], onDelete: Cascade)
  order      Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([generationId])
  @@index([createdAt])
  @@map("image_downloads")
}

// ---------------------------------------------------------------------------
// Image Likes
// ---------------------------------------------------------------------------

model ImageLike {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  generationId String   @map("generation_id")
  imageIndex   Int      @map("image_index")
  imageType    String   @default("preview") @map("image_type")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([generationId])
  @@index([createdAt])
  @@map("image_likes")
}

// ---------------------------------------------------------------------------
// Invite Events
// ---------------------------------------------------------------------------

model InviteEvent {
  id            String   @id @default(cuid())
  inviterId     String?  @map("inviter_id")
  inviteeId     String?  @map("invitee_id")
  inviterCode   String?  @map("inviter_code")
  rewardCredits Int      @default(0) @map("reward_credits")
  createdAt     DateTime @default(now()) @map("created_at")

  inviter User? @relation("InviterEvents", fields: [inviterId], references: [id], onDelete: SetNull)
  invitee User? @relation("InviteeEvents", fields: [inviteeId], references: [id], onDelete: SetNull)

  @@index([inviterId])
  @@index([inviteeId])
  @@index([createdAt])
  @@map("invite_events")
}

// ---------------------------------------------------------------------------
// Model Configs
// ---------------------------------------------------------------------------

model ModelConfig {
  id          String           @id @default(cuid())
  type        ModelConfigType
  name        String
  apiBaseUrl  String           @map("api_base_url")
  apiKey      String           @map("api_key")
  modelName   String           @map("model_name")
  status      ModelConfigStatus @default(inactive)
  description String?
  source      ModelConfigSource @default(openAi)
  createdBy   String?          @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  createdByUser User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@map("model_configs")
}

// ---------------------------------------------------------------------------
// Single Generations
// ---------------------------------------------------------------------------

model SingleGeneration {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  prompt       String
  originalImage String  @map("original_image")
  resultImage  String   @map("result_image")
  settings     Json     @default("{}")
  creditsUsed  Int      @default(15) @map("credits_used")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("single_generations")
}

// ---------------------------------------------------------------------------
// System Announcements
// ---------------------------------------------------------------------------

model SystemAnnouncement {
  id          String    @id @default(cuid())
  content     String
  isActive    Boolean   @default(false) @map("is_active")
  publishedAt DateTime  @default(now()) @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([publishedAt])
  @@map("system_announcements")
}
