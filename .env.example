# ============================================================
# AI Wedding 环境变量配置
# ============================================================
#
# 配置说明：
# - 🔴 [必需] 缺少会导致应用无法启动
# - 🟡 [推荐] 影响核心功能，应该配置
# - 🟢 [可选] 有默认值，可按需调整
#
# 完整文档：docs/deployment/environment-vars.md
# ============================================================

# ============================================================
# 🔴 数据库配置（必需）
# ============================================================
# PostgreSQL 连接字符串
# 格式：postgresql://[用户名]:[密码]@[主机]:[端口]/[数据库名]
DATABASE_URL="postgresql://aiwedding:password123@localhost:5432/ai_wedding"

# 示例：
# - 本地开发：postgresql://aiwedding:dev123@localhost:5432/ai_wedding_dev
# - Docker 内部：postgresql://aiwedding:password@postgres:5432/ai_wedding
# - 云数据库：postgresql://user:pass@your-rds.example.com:5432/ai_wedding

# 仅用于 grant-db-permissions 脚本：postgres 管理员密码（勿提交）
# PG_ADMIN_PASSWORD=

# ============================================================
# 🔴 认证配置（必需）
# ============================================================
# NextAuth 应用访问地址
# 开发环境：http://localhost:3000
# 生产环境：https://your-domain.com（必须使用 HTTPS）
NEXTAUTH_URL="http://localhost:3000"

# NextAuth 会话加密密钥（32 字节随机字符串）
# 生成命令：openssl rand -base64 32
# ⚠️ 生产环境必须更换为随机值
NEXTAUTH_SECRET="your-random-secret-here-change-in-production"

# ============================================================
# 🔴 AI 模型配置（必需）
# ============================================================
# API 模式选择：
#   - images: 使用 /v1/images/generations 接口（适用于 DALL-E 3）
#   - chat: 使用 /v1/chat/completions 流式接口（适用于 Gemini 2.5）
IMAGE_API_MODE=images

# API 基础地址
# OpenAI: https://api.openai.com
# OpenRouter: https://openrouter.ai/api/v1
# 302.ai: https://api.302.ai
IMAGE_API_BASE_URL=https://api.openai.com

# API 密钥（必需）
# OpenAI 格式：sk-proj-xxxxx
# 其他服务请参考对应文档
IMAGE_API_KEY=sk-your-api-key-here

# images 模式使用的模型（当 IMAGE_API_MODE=images 时生效）
IMAGE_IMAGE_MODEL=dall-e-3

# chat 模式使用的模型（当 IMAGE_API_MODE=chat 时生效）
IMAGE_CHAT_MODEL=gemini-2.5-flash-image

# ============================================================
# 🔴 对象存储配置（必需）
# ============================================================
# 存储提供商：minio（自托管）或 oss（阿里云 OSS）
# 推荐：开发环境用 minio，生产环境用 oss
STORAGE_PROVIDER=minio

# ------------------------------------------------------------
# MinIO 配置（当 STORAGE_PROVIDER=minio 时生效）
# ------------------------------------------------------------
# MinIO 服务端点
# 本地开发：http://localhost:9000
# Docker 内部：http://minio:9000
# 生产环境：https://minio.your-domain.com
MINIO_ENDPOINT="http://localhost:9000"

# MinIO 访问密钥（默认：minioadmin / minioadmin）
# ⚠️ 生产环境必须更换为强密码
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"

# MinIO 存储桶名称
MINIO_BUCKET_NAME="ai-images"

# 是否使用 SSL（生产环境建议 true）
MINIO_USE_SSL="false"

# ------------------------------------------------------------
# 阿里云 OSS 配置（当 STORAGE_PROVIDER=oss 时生效）
# ------------------------------------------------------------
# OSS 区域（例如：oss-cn-hangzhou, oss-cn-beijing）
ALI_OSS_REGION="oss-cn-hangzhou"

# OSS 访问密钥（从阿里云控制台获取）
ALI_OSS_ACCESS_KEY_ID=""
ALI_OSS_ACCESS_KEY_SECRET=""

# OSS 存储桶名称
ALI_OSS_BUCKET=""

# ============================================================
# 🟡 支付配置（推荐）
# ============================================================
# 支付提供商：mock（测试）或 stripe（生产）
PAYMENT_PROVIDER=mock

# Stripe 配置（仅在 PAYMENT_PROVIDER=stripe 时需要）
# STRIPE_SECRET_KEY=sk_live_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================================
# 🟡 初始管理员账号（推荐首次部署时配置）
# ============================================================
# 首次启动时自动创建管理员账号（seed 阶段执行）
# 如果该邮箱已注册，则自动将其提升为管理员角色
# 配置后可通过该账号登录并访问 /admin 管理后台
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-please"

# 种子数据中模型配置使用的 API 地址和 Key（可选）
# 如果不设置，将使用 IMAGE_API_BASE_URL / IMAGE_API_KEY 作为默认值
# SEED_MODEL_API_BASE_URL=https://api.example.com
# SEED_MODEL_API_KEY=sk-your-model-api-key

# ============================================================
# 🟢 应用配置（可选）
# ============================================================
# 应用运行端口（默认：3000）
PORT=3000

# Node.js 环境（development | production）
NODE_ENV=production

# 禁用 Next.js 遥测
NEXT_TELEMETRY_DISABLED=1

# SSR 认证守卫（保护 /dashboard, /results/*, /create 等路由）
# 生产环境建议设为 true，开发环境可设为 false
ENABLE_SSR_GUARD=true

# 启用访客模式（允许未登录用户生成图片）
# ENABLE_GUEST_MODE=false

# ============================================================
# 🟢 安全配置（可选）
# ============================================================
# SSL 证书验证（仅用于开发环境或信任的内网环境）
# ⚠️ 警告：生产环境请勿启用，会导致安全风险
DISABLE_SSL_VERIFY=false

# ============================================================
# 🟢 速率限制（可选）
# ============================================================
# 每个用户每小时最大生成次数
# RATE_LIMIT_PER_HOUR=10

# 每个 IP 每小时最大请求次数
# RATE_LIMIT_PER_IP=100

# ============================================================
# 🟢 日志配置（可选）
# ============================================================
# 日志级别：debug | info | warn | error
# LOG_LEVEL=info

# 日志格式：json | pretty
# LOG_FORMAT=json

# ============================================================
# 🟢 Docker 配置（仅 Docker Compose 使用）
# ============================================================
# PostgreSQL 配置（Docker Compose 自动创建）
# POSTGRES_USER=aiwedding
# POSTGRES_PASSWORD=aiwedding123
# POSTGRES_DB=ai_wedding
# POSTGRES_PORT=5432

# MinIO 配置（Docker Compose 自动创建）
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# 应用端口
# APP_PORT=3000

# ============================================================
# 🟢 PM2 配置（仅 PM2 部署使用）
# ============================================================
# PM2 实例数量（cluster 模式）
# PM2_INSTANCES=1

# PM2 最大内存限制
# PM2_MAX_MEMORY=1G

# 应用目录
# APP_DIR=/var/www/ai-wedding

# ============================================================
# 配置检查清单
# ============================================================
#
# 开发环境最小配置：
# ✅ DATABASE_URL（本地 PostgreSQL）
# ✅ NEXTAUTH_SECRET（随机生成）
# ✅ NEXTAUTH_URL（http://localhost:3000）
# ✅ IMAGE_API_KEY（测试 API Key）
# ✅ STORAGE_PROVIDER=minio（Docker 启动）
#
# 生产环境必需配置：
# ✅ DATABASE_URL（云数据库）
# ✅ NEXTAUTH_SECRET（强随机密钥）
# ✅ NEXTAUTH_URL（HTTPS 域名）
# ✅ IMAGE_API_KEY（生产 API Key）
# ✅ STORAGE_PROVIDER=oss（推荐）
# ✅ ALI_OSS_* 配置（如使用 OSS）
# ✅ PAYMENT_PROVIDER=stripe（如需支付）
# ✅ ENABLE_SSR_GUARD=true
#
# ============================================================
