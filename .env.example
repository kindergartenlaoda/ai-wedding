# PostgreSQL (Prisma)
DATABASE_URL="postgresql://user:password@host:5432/database"

# 仅用于 grant-db-permissions 脚本：postgres 管理员密码（勿提交）
# PG_ADMIN_PASSWORD=

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-secret-here"

# 服务器端密钥（不要以 NEXT_PUBLIC_ 开头，避免泄露）
# 模式选择：
#   - images: 使用 /v1/images/generations 接口（适用于 DALL-E）
#   - chat: 使用 /v1/chat/completions 流式接口（适用于 gemini-2.5-flash-image 等）
IMAGE_API_MODE=chat

# 通用基础配置（优先使用 IMAGE_*，否则回退 OPENAI_*）
IMAGE_API_BASE_URL=https://api.openai.com
IMAGE_API_KEY=

# images/generations 模型（如使用 OpenAI）
IMAGE_IMAGE_MODEL=dall-e-3

# chat/completions 图像模型（用于流式生成，例如 gemini-2.5-flash-image）
# 当 IMAGE_API_MODE=chat 时生效
IMAGE_CHAT_MODEL=gemini-2.5-flash-image

# 对象存储配置
# STORAGE_PROVIDER: minio（默认，自建 MinIO）或 oss（阿里云 OSS）
STORAGE_PROVIDER=minio

# MinIO 对象存储配置（当 STORAGE_PROVIDER=minio 时生效）
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET_NAME="ai-images"
MINIO_USE_SSL="false"

# SSL 证书验证配置（仅用于开发环境或信任的内网环境）
# 设置为 true 可禁用 SSL 证书验证，解决自签名证书问题
# ⚠️ 警告：生产环境请勿启用此选项，会导致安全风险
DISABLE_SSL_VERIFY=false

# 阿里云 OSS 对象存储配置（当 STORAGE_PROVIDER=oss 时生效）
ALI_OSS_REGION="oss-cn-hangzhou"
ALI_OSS_ACCESS_KEY_ID=""
ALI_OSS_ACCESS_KEY_SECRET=""
ALI_OSS_BUCKET=""

# 支付配置
# PAYMENT_PROVIDER: mock（默认，模拟支付）或 stripe（真实 Stripe 支付）
PAYMENT_PROVIDER=mock
# Stripe 密钥（仅在 PAYMENT_PROVIDER=stripe 时需要）
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# SSR 认证守卫（保护 /dashboard, /results/*, /create 等路由）
# 生产环境建议设为 true，确保未登录用户在服务端即被重定向
# 开发环境可设为 false 以简化调试
ENABLE_SSR_GUARD=true
