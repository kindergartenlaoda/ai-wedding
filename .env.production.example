# ============================================================
# 生产环境配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env.production
#   2. 填写所有必需配置
#   3. 使用 docker-compose.prod.yml 部署
# ============================================================

# ============================================================
# 🔴 数据库配置（必需 - 使用云数据库）
# ============================================================
DATABASE_URL="postgresql://user:password@your-rds.example.com:5432/ai_wedding"

# ============================================================
# 🔴 认证配置（必需 - 必须使用 HTTPS）
# ============================================================
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="your-production-secret-here-use-openssl-rand-base64-32"

# ============================================================
# 🔴 AI 模型配置（必需）
# ============================================================
IMAGE_API_MODE=images
IMAGE_API_BASE_URL=https://api.openai.com
IMAGE_API_KEY=sk-prod-your-api-key-here
IMAGE_IMAGE_MODEL=dall-e-3
IMAGE_CHAT_MODEL=gemini-2.5-flash-image

# ============================================================
# 🔴 对象存储配置（必需 - 推荐阿里云 OSS）
# ============================================================
STORAGE_PROVIDER=oss
ALI_OSS_REGION=oss-cn-beijing
ALI_OSS_ACCESS_KEY_ID=your-access-key-id
ALI_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALI_OSS_BUCKET=your-bucket-name

# ============================================================
# 🟡 管理员配置（推荐）
# ============================================================
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=your-secure-admin-password

# ============================================================
# 🟡 安全配置（推荐）
# ============================================================
ENABLE_SSR_GUARD=true

# ============================================================
# 🟡 支付配置（如需要）
# ============================================================
PAYMENT_PROVIDER=stripe
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================================
# 🟢 应用配置（可选）
# ============================================================
APP_PORT=3000
NEXT_PUBLIC_APP_NAME="AI Wedding"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ============================================================
# 🟢 日志配置（可选）
# ============================================================
LOG_LEVEL=info
