# Local administrator mode: no login, database, credit, or object-storage service required.
# Copy this file to .env, then set IMAGE_API_BASE_URL, IMAGE_API_KEY, and the model.

LOCAL_ADMIN_MODE=true
NEXT_PUBLIC_LOCAL_ADMIN_MODE=true
ENABLE_SSR_GUARD=false

NEXTAUTH_URL=http://127.0.0.1:3000
NEXTAUTH_SECRET=replace-with-a-random-local-secret

# Prisma requires a syntactically valid URL, but local admin routes do not require
# this database to be running.
DATABASE_URL=postgresql://local:local@127.0.0.1:5432/ai_wedding

IMAGE_API_MODE=images
IMAGE_API_BASE_URL=https://api.example.com/v1
IMAGE_API_KEY=replace-with-your-api-key
IMAGE_IMAGE_MODEL=gpt-image-2
IMAGE_CHAT_MODEL=gpt-image-2

IMAGE_OUTPUT_SIZE=1024x1536
IMAGE_OUTPUT_QUALITY=high
IMAGE_NATIVE_HD_TIMEOUT_MS=60000
IMAGE_API_REQUEST_TIMEOUT_MS=180000

# Local admin mode falls back to data URLs when MinIO is unavailable.
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ai-images
MINIO_USE_SSL=false

PAYMENT_PROVIDER=mock
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=local-admin
PORT=3000
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
