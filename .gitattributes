# 自动检测文本文件并标准化行结束符
* text=auto

# 明确指定文本文件使用 LF
*.sh text eol=lf
*.bash text eol=lf
docker-entrypoint.sh text eol=lf

# Windows 脚本使用 CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# 源代码文件使用 LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
